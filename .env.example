# Copy this file to .env beside CTF-BTFly.exe, then fill in your own values.
# Never commit the real .env file or any provider credential.
CTF_UPSTREAM_MODEL_BASE_URL=https://your-openai-compatible-endpoint/v1
CTF_UPSTREAM_MODEL_API_KEY=replace-with-your-own-api-key
CTF_MODEL_ID=your-model-id

# Optional: request usage information from compatible streaming APIs.
CTF_MODEL_INCLUDE_STREAM_USAGE=true

# Optional: Docker Desktop's default Windows/Linux engine pipe.
# DOCKER_HOST=npipe:////./pipe/dockerDesktopLinuxEngine
